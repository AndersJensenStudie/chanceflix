pub mod Chance.Currency {
    use Chance.Currency
    pub enum Cur with ToString, Eq, Order {
        case AFN, EUR, ALL, DZD, USD, AOA, XCD, XAD, ARS, AMD, AWG, AZN, BSD, BHD, BDT, BBD, BYN, BZD, XOF, BMD, INR, BTN, BOB, BOV, BAM, BWP, NOK, BRL, BND, BIF, CVE, KHR, XAF, CAD, KYD, CLP, CLF, CNY, AUD, COP, COU, KMF, CDF, NZD, CRC, CUP, XCG, CZK, DKK, DJF, DOP, EGP, SVC, ERN, SZL, ETB, FKP, FJD, XPF, GMD, GEL, GHS, GIP, GTQ, GBP, GNF, GYD, HTG, HNL, HKD, HUF, ISK, IDR, XDR, IRR, IQD, ILS, JMD, JPY, JOD, KZT, KES, KPW, KRW, KWD, KGS, LAK, LBP, LSL, ZAR, LRD, LYD, CHF, MOP, MGA, MWK, MYR, MVR, MRU, MUR, XUA, MXN, MXV, MDL, MNT, MAD, MZN, MMK, NAD, NPR, NIO, NGN, MKD, OMR, PKR, PAB, PGK, PYG, PEN, PHP, PLN, QAR, RON, RUB, RWF, SHP, WST, STN, SAR, RSD, SCR, SLE, SGD, XSU, SBD, SOS, SSP, LKR, SDG, SRD, SEK, CHE, CHW, SYP, TWD, TJS, TZS, THB, TOP, TTD, TND, TRY, TMT, UGX, UAH, AED, USN, UYU, UYI, UYW, UZS, VUV, VES, VED, VND, YER, ZMW, ZWG, XBA, XBB, XBC, XBD, XAU, XPD, XPT, XAG
    }

    pub def currencyPair(): (Cur, Cur) \ Currency = 
        Chance.unique(() -> Currency.currency(), 2)
        |> (lst) -> (Option.getWithDefault(unreachable!(), List.head(lst)), Option.getWithDefault(unreachable!(), List.nth(1, lst)))

    def getValues(): Vector[Cur] = Vector#{
        Cur.AFN, Cur.EUR, Cur.ALL, Cur.DZD, Cur.USD, Cur.AOA, Cur.XCD, Cur.XAD, 
        Cur.ARS, Cur.AMD, Cur.AWG, Cur.AUD, Cur.AZN, Cur.BSD, Cur.BHD, Cur.BDT, 
        Cur.BBD, Cur.BYN, Cur.BZD, Cur.XOF, Cur.BMD, Cur.INR, Cur.BTN, Cur.BOB, 
        Cur.BOV, Cur.BAM, Cur.BWP, Cur.NOK, Cur.BRL, Cur.BND, Cur.BIF, Cur.CVE, 
        Cur.KHR, Cur.XAF, Cur.CAD, Cur.KYD, Cur.CLP, Cur.CLF, Cur.CNY, Cur.COP, 
        Cur.COU, Cur.KMF, Cur.CDF, Cur.NZD, Cur.CRC, Cur.CUP, Cur.XCG, Cur.CZK, 
        Cur.DKK, Cur.DJF, Cur.DOP, Cur.EGP, Cur.SVC, Cur.ERN, Cur.SZL, Cur.ETB, 
        Cur.FKP, Cur.FJD, Cur.XPF, Cur.GMD, Cur.GEL, Cur.GHS, Cur.GIP, Cur.GTQ, 
        Cur.GBP, Cur.GNF, Cur.GYD, Cur.HTG, Cur.HNL, Cur.HKD, Cur.HUF, Cur.ISK, 
        Cur.IDR, Cur.XDR, Cur.IRR, Cur.IQD, Cur.ILS, Cur.JMD, Cur.JPY, Cur.JOD, 
        Cur.KZT, Cur.KES, Cur.KPW, Cur.KRW, Cur.KWD, Cur.KGS, Cur.LAK, Cur.LBP, 
        Cur.LSL, Cur.ZAR, Cur.LRD, Cur.LYD, Cur.CHF, Cur.MOP, Cur.MGA, Cur.MWK, 
        Cur.MYR, Cur.MVR, Cur.MRU, Cur.MUR, Cur.XUA, Cur.MXN, Cur.MXV, Cur.MDL, 
        Cur.MNT, Cur.MAD, Cur.MZN, Cur.MMK, Cur.NAD, Cur.NPR, Cur.NIO, Cur.NGN, 
        Cur.MKD, Cur.OMR, Cur.PKR, Cur.PAB, Cur.PGK, Cur.PYG, Cur.PEN, Cur.PHP, 
        Cur.PLN, Cur.QAR, Cur.RON, Cur.RUB, Cur.RWF, Cur.SHP, Cur.WST, Cur.STN, 
